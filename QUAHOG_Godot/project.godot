3d_physics/layer_2="Player"
3d_physics/layer_3="NPC"
3d_physics/layer_4="Vehicle"
3d_physics/layer_5="Projectile"
3d_physics/layer_6="Interactable"
3d_physics/layer_7="Trigger"
3d_physics/layer_8="Pickup"
