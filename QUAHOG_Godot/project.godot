; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Project QUAHOG - South Coast"
config/description="GTA-style open world game set on the Massachusetts South Coast, 1986."
config/version="0.1.0"
run/main_scene="res://scenes/world/Game.tscn"
config/features=PackedStringArray("4.2", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://autoloads/GameManager.gd"
PlayerWallet="*res://autoloads/PlayerWallet.gd"
SaveLoadManager="*res://autoloads/SaveLoadManager.gd"
InputManager="*res://autoloads/InputManager.gd"
TimeOfDayClock="*res://autoloads/TimeOfDayClock.gd"
WeatherController="*res://autoloads/WeatherController.gd"
HeatManager="*res://autoloads/HeatManager.gd"
SafehouseManager="*res://autoloads/SafehouseManager.gd"
RadioManager="*res://autoloads/RadioManager.gd"
RevenueManager="*res://autoloads/RevenueManager.gd"
MissionManager="*res://autoloads/MissionManager.gd"
GloriaEventDirector="*res://autoloads/GloriaEventDirector.gd"
HUDManager="*res://autoloads/HUDManager.gd"
PostProcessManager="*res://autoloads/PostProcessManager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/resizable=true
window/stretch/mode="canvas_items"

