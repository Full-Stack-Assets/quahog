# =============================================================
# QUAHOG — Unity .gitignore
# Rename this file to ".gitignore" and place it at the PROJECT ROOT
# (the folder that contains Assets/, Packages/, ProjectSettings/).
# =============================================================

# Unity generated / project-local folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# Never ignore .meta files for assets that ARE tracked
!/[Aa]ssets/**/*.meta

# Autogenerated IDE / solution / project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files for ignored binaries
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity crash reports
sysinfo.txt

# Build artifacts
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics
crashlytics-build.properties

# macOS / editor cruft
.DS_Store
.vs/
.vscode/
.idea/
