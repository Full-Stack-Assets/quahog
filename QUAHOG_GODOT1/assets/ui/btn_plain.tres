[gd_resource type="StyleBoxFlat" format=3]

; Plain default button background (dark slate with a thin warm border, rounded).
; Replaces the ornate "Play" image as the theme-wide Button style so ordinary
; buttons (HUD, map travel list, cheats) don't all render the Play art. Generous
; content margins make buttons bigger/tappable by default.
[resource]
bg_color = Color(0.11, 0.12, 0.15, 0.94)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.79, 0.62, 0.28, 0.85)
corner_radius_top_left = 8
corner_radius_top_right = 8
corner_radius_bottom_right = 8
corner_radius_bottom_left = 8
content_margin_left = 20.0
content_margin_top = 14.0
content_margin_right = 20.0
content_margin_bottom = 14.0
